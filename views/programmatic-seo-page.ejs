<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= data.title %></title><meta name="description" content="<%= data.description %>" /><meta name="keywords" content="<%= data.keyword %>, Claude to PDF, AI conversation export, searchable PDF" /><link rel="canonical" href="https://claude2pdf.up.railway.app/tools/<%= data.slug %>" /><link rel="icon" type="image/svg+xml" href="/favicon.svg" /> <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <% if (data.noindex) { %><meta name="robots" content="noindex, follow" /><% } %>
  <meta property="og:type" content="article" /><meta property="og:locale" content="en_US" /><meta property="og:site_name" content="Claude2PDF" /><meta property="og:url" content="https://claude2pdf.up.railway.app/tools/<%= data.slug %>" /><meta property="og:title" content="<%= data.title %>" /><meta property="og:description" content="<%= data.description %>" />
  <meta name="twitter:card" content="summary" /><meta name="twitter:title" content="<%= data.title %>" /><meta name="twitter:description" content="<%= data.description %>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin /><link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet" /><link rel="stylesheet" href="/site-pages.css" />
  <% if (data.faqs && data.faqs.length) { %><script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[<% data.faqs.forEach((faq,index)=>{ %>{"@type":"Question","name":<%- JSON.stringify(faq.q) %>,"acceptedAnswer":{"@type":"Answer","text":<%- JSON.stringify(faq.a) %>}}<%= index < data.faqs.length-1 ? ',' : '' %><% }) %>]}</script><% } %>
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"WebPage","name":<%- JSON.stringify(data.h1) %>,"description":<%- JSON.stringify(data.description) %>,"url":"https://claude2pdf.up.railway.app/tools/<%= data.slug %>","inLanguage":"en-US","isPartOf":{"@type":"WebSite","name":"Claude2PDF","url":"https://claude2pdf.up.railway.app/"}}</script>
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Claude2PDF","item":"https://claude2pdf.up.railway.app/"},{"@type":"ListItem","position":2,"name":"Tools","item":"https://claude2pdf.up.railway.app/tools"},{"@type":"ListItem","position":3,"name":<%- JSON.stringify(data.h1) %>,"item":"https://claude2pdf.up.railway.app/tools/<%= data.slug %>"}]}</script>
</head>
<body>
  <%- include('partials/site-header', { current: 'tools' }) %>
  <main class="page-main">
    <section class="page-hero site-shell"><ol class="breadcrumbs" aria-label="Breadcrumb"><li><a href="/">Home</a></li><li>/</li><li><a href="/tools">Tools</a></li></ol><span class="eyebrow" style="margin-top:22px"><%= data.keyword %></span><h1 class="page-title"><%= data.h1 %></h1><p class="page-lede"><%= data.intro %></p><div class="hero-actions"><a class="button-primary" href="/"><%= data.ctaText || 'Start converting' %></a><a class="button-secondary" href="/how-it-works">How it works</a></div></section>
    <section class="section site-shell"><article class="article-card"><h2>Built for: <%= data.keyword %></h2><p><%= data.useCase %></p></article><% if (data.sections && data.sections.length) { data.sections.forEach(section => { %><article class="article-card"><h2><%= section.title %></h2><p><%= section.content %></p></article><% }) } %></section>
    <section class="section section--soft"><div class="site-shell"><div class="section-head"><p class="section-kicker">Process</p><h2 class="section-title">How the conversion works.</h2></div><div class="process-diagram"><div class="process-node"><span class="card-index">1</span><strong>Paste a public link</strong><span>Use a supported public AI conversation share URL.</span></div><div class="process-node"><span class="card-index">2</span><strong>Extract the page</strong><span>The server temporarily retrieves the public conversation HTML.</span></div><div class="process-node"><span class="card-index">3</span><strong>Review the preview</strong><span>Your browser parses and formats the conversation.</span></div><div class="process-node"><span class="card-index">4</span><strong>Save the PDF</strong><span>Your browser creates the final searchable PDF.</span></div></div></div></section>
    <% if (data.faqs && data.faqs.length) { %><section class="section site-shell"><div class="section-head"><p class="section-kicker">Questions</p><h2 class="section-title">Common questions.</h2></div><div class="faq-stack"><% data.faqs.forEach(faq => { %><article class="faq-item"><h3><%= faq.q %></h3><p><%= faq.a %></p></article><% }) %></div></section><% } %>
    <% if (data.relatedSlugs && data.relatedSlugs.length) { %><section class="section site-shell"><div class="section-head"><p class="section-kicker">Related</p><h2 class="section-title">More export guides.</h2></div><div class="tool-grid"><% data.relatedSlugs.forEach(slug => { const related = allPages.find(p => p.slug === slug); if (related) { %><a class="tool-card" href="/tools/<%= related.slug %>"><span class="tool-card__tag">Guide</span><h3><%= related.title.split('|')[0].trim() %></h3><p><%= related.description %></p><span class="tool-card__more">Read guide <span>→</span></span></a><% } }) %></div></section><% } %>
  </main>
  <%- include('partials/site-footer') %>
</body></html>
