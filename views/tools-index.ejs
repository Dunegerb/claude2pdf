<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Claude to PDF Tools & AI Chat Export Guides | Claude2PDF</title>
  <meta name="description" content="Explore Claude to PDF, export, download, save, and print guides, plus dedicated ChatGPT, Gemini, and Grok conversion workflows." />
  <link rel="canonical" href="https://claude2pdf.up.railway.app/tools" /><link rel="icon" type="image/svg+xml" href="/favicon.svg" /> <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta property="og:type" content="website" /><meta property="og:title" content="Claude to PDF Tools & AI Chat Export Guides | Claude2PDF" /><meta property="og:description" content="Claude-first guides for exporting, downloading, saving, and printing AI conversations." /><meta property="og:url" content="https://claude2pdf.up.railway.app/tools" />
  <meta name="twitter:card" content="summary" /><meta name="twitter:title" content="Claude to PDF Tools & AI Chat Export Guides" /><meta name="twitter:description" content="Claude-first guides for exporting, downloading, saving, and printing AI conversations." />
  <link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin /><link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet" /><link rel="stylesheet" href="/site-pages.css" />
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"CollectionPage","name":"Claude2PDF Tools and Guides","url":"https://claude2pdf.up.railway.app/tools","description":"Claude to PDF guides and dedicated export workflows for other AI conversations.","mainEntity":{"@type":"ItemList","numberOfItems":<%= pages.length %>,"itemListElement":[<% pages.forEach((page,index)=>{ %>{"@type":"ListItem","position":<%= index+1 %>,"url":"https://claude2pdf.up.railway.app/tools/<%= page.slug %>","name":<%- JSON.stringify(page.title.split('|')[0].trim()) %>}<%= index < pages.length-1 ? ',' : '' %><% }) %>]}}</script>
</head>
<body>
  <%- include('partials/site-header', { current: 'tools' }) %>
  <main class="page-main">
    <section class="page-hero site-shell"><span class="eyebrow">Tools & guides</span><h1 class="page-title">Claude to PDF tools for clean, searchable exports.</h1><p class="page-lede">Start with Claude export, download, save, and print workflows, or use dedicated guides for ChatGPT, Gemini, and Grok.</p><div class="hero-actions"><a class="button-primary" href="/">Open converter</a><a class="button-secondary" href="/features">View features</a></div></section>
    <section class="section site-shell"><div class="section-head"><p class="section-kicker">Library</p><h2 class="section-title"><%= pages.length %> focused export workflows.</h2><p class="section-copy">Each guide explains a specific use case and links back to the main converter when the workflow is supported.</p></div><div class="tool-grid"><% pages.forEach(page => { %><a href="/tools/<%= page.slug %>" class="tool-card"><span class="tool-card__tag">Guide</span><h2><%= page.title.split('|')[0].trim() %></h2><p><%= page.description %></p><span class="tool-card__more">Read guide <span>→</span></span></a><% }) %></div></section>
    <section class="section site-shell"><div class="callout"><div><h2>Need the product overview instead?</h2><p>See supported providers, privacy architecture, output capabilities and honest limitations.</p></div><a class="button-secondary" href="/features">Explore features</a></div></section>
  </main>
  <%- include('partials/site-footer') %>
</body></html>
