  <script type="application/ld+json">{"@context":"https://schema.org","@type":"SoftwareApplication","name":"Claude2PDF","applicationCategory":"UtilitiesApplication","operatingSystem":"Web","url":"https://claude2pdf.up.railway.app/","description":"A web application that converts public Claude, ChatGPT, Gemini and Grok share links into searchable PDF documents.","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"featureList":["Claude public share-link parsing","ChatGPT public share-link parsing","Gemini public share-link parsing","Grok public share-link parsing","Searchable PDF export","Browser preview","Formatting preservation"]}</script>
